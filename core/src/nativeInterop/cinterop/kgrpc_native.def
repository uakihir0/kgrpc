headers = include/kgrpc_native.h
compilerOpts = -I../native/
package = work.socialhub.kgrpc.native
staticLibraries = libkgrpc_native.a

# apple
libraryPaths.ios_arm64 = ../native/target/aarch64-apple-ios/release
libraryPaths.ios_simulator_arm64 = ../native/target/aarch64-apple-ios-sim/release
libraryPaths.macos_arm64 = ../native/target/aarch64-apple-darwin/release
libraryPaths.macos_x64 = ../native/target/x86_64-apple-darwin/release
libraryPaths.ios_x64 = ../native/target/x86_64-apple-ios/release

# linux
libraryPaths.linux_x64 = ../native/target/x86_64-unknown-linux-gnu/release

# windows
libraryPaths.mingw_x64 = ../native/target/x86_64-pc-windows-gnu/release
